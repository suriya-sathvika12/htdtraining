@model IEnumerable<NorthwindMVC.Models.Order>

<h2>Orders of Employee 5</h2>

<table class="table table-bordered">

    <tr>
        <th>Order ID</th>
        <th>Employee ID</th>
        <th>Ship Name</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.OrderID</td>
            <td>@item.EmployeeID</td>
            <td>@item.ShipName</td>
        </tr>
    }

</table>