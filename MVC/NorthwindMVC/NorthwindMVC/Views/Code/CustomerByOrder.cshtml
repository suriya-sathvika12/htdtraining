
@model NorthwindMVC.Customer

<h2>Customer Details For Order 10248</h2>

<table border="1">
    <tr>
        <td>Customer ID</td>
        <td>@Model.CustomerID</td>
    </tr>

    <tr>
        <td>Company Name</td>
        <td>@Model.CompanyName</td>
